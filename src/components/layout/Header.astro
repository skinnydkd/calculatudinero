---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/declaracion-renta/', label: 'Renta 2025', highlight: true },
  { href: '/autonomos/', label: 'Autónomos', highlight: false },
  { href: '/laboral/', label: 'Laboral', highlight: false },
  { href: '/impuestos/', label: 'Impuestos', highlight: false },
  { href: '/vivienda/', label: 'Vivienda', highlight: false },
  { href: '/ahorro-inversion/', label: 'Ahorro', highlight: false },
];
---

<header class="header">
  <div class="header__inner container">
    <a href="/" class="header__logo" aria-label="CalculaTuDinero - Inicio">
      Calcula<span class="header__logo-accent">Tu</span>Dinero
    </a>

    <input
      type="checkbox"
      id="menu-toggle"
      class="header__menu-toggle visually-hidden"
      aria-label="Abrir menú de navegación"
    />
    <label for="menu-toggle" class="header__hamburger" aria-hidden="true">
      <span class="header__hamburger-bar"></span>
      <span class="header__hamburger-bar"></span>
      <span class="header__hamburger-bar"></span>
    </label>

    <nav class="header__nav" aria-label="Navegación principal">
      <ul class="header__nav-list">
        {navLinks.map(({ href, label, highlight }) => (
          <li>
            <a
              href={href}
              class:list={[
                'header__nav-link',
                { 'header__nav-link--active': currentPath.startsWith(href) },
                { 'header__nav-link--highlight': highlight },
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  /* Logo */
  .header__logo {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .header__logo:hover {
    color: var(--color-text);
  }

  .header__logo-accent {
    color: var(--color-accent);
  }

  /* Nav */
  .header__nav-list {
    display: flex;
    gap: var(--space-6);
    list-style: none;
  }

  .header__nav-link {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-2) 0;
    border-bottom: 2px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .header__nav-link:hover,
  .header__nav-link--active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .header__nav-link--highlight {
    color: #fff;
    background-color: var(--color-accent);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    border-bottom: none;
    font-weight: 600;
    font-size: 0.85rem;
  }

  .header__nav-link--highlight:hover {
    background-color: var(--color-accent-hover, #A8461F);
    color: #fff;
    border-bottom: none;
  }

  /* Hamburger — hidden on desktop */
  .header__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 28px;
    height: 28px;
    cursor: pointer;
  }

  .header__hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 1px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .header__hamburger {
      display: flex;
    }

    .header__nav {
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background-color: var(--color-surface);
      box-shadow: var(--shadow-md);
      max-height: 0;
      overflow: hidden;
      transition: max-height var(--transition-base);
    }

    .header__nav-list {
      flex-direction: column;
      gap: 0;
      padding: 0;
    }

    .header__nav-link {
      display: block;
      padding: var(--space-4) var(--space-4);
      border-bottom: 1px solid var(--color-border);
    }

    .header__nav-link:last-child {
      border-bottom: none;
    }

    /* Open state */
    .header__menu-toggle:checked ~ .header__nav {
      max-height: 300px;
    }

    /* Animate hamburger to X */
    .header__menu-toggle:checked ~ .header__hamburger .header__hamburger-bar:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .header__menu-toggle:checked ~ .header__hamburger .header__hamburger-bar:nth-child(2) {
      opacity: 0;
    }

    .header__menu-toggle:checked ~ .header__hamburger .header__hamburger-bar:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Calculadoras Financieras para España — CalculaTuDinero.net';
const description = 'Calculadoras financieras gratuitas, actualizadas y precisas para autónomos y trabajadores en España. Calcula tu salario neto, facturación e indemnización.';

const calculators = [
  {
    icon: '💼',
    title: 'Cuánto facturar como autónomo',
    description: 'Calcula cuánto debes facturar para alcanzar el sueldo neto que deseas, incluyendo cuota de autónomos e IRPF.',
    href: '/autonomos/cuanto-facturar/',
  },
  {
    icon: '💰',
    title: 'Salario neto',
    description: 'Calcula tu salario neto a partir del bruto, con las retenciones de Seguridad Social e IRPF de tu comunidad autónoma.',
    href: '/laboral/salario-neto/',
  },
  {
    icon: '⚖️',
    title: 'Indemnización por despido',
    description: 'Calcula la indemnización que te corresponde según el tipo de despido, tu antigüedad y salario.',
    href: '/laboral/indemnizacion-despido/',
  },
  {
    icon: '🧾',
    title: 'Calculadora de IRPF 2026',
    description: 'Calcula tu cuota de IRPF con los tramos estatales y autonómicos actualizados. Para trabajadores y autónomos.',
    href: '/impuestos/calculadora-irpf/',
  },
  {
    icon: '📋',
    title: 'Cuota de Autónomos 2026',
    description: 'Descubre qué cuota de autónomos te corresponde según tus rendimientos netos con el sistema de cotización por ingresos reales.',
    href: '/autonomos/cuota-autonomos/',
  },
  {
    icon: '📄',
    title: 'Calculadora de Finiquito',
    description: 'Calcula tu finiquito: días trabajados, vacaciones pendientes y prorrata de pagas extra.',
    href: '/laboral/finiquito/',
  },
  {
    icon: '🏠',
    title: 'Simulador de Hipoteca',
    description: 'Calcula tu cuota mensual, total de intereses y cuadro de amortización. Incluye gastos de compra por comunidad autónoma.',
    href: '/vivienda/calculadora-hipoteca/',
  },
  {
    icon: '📈',
    title: 'Interés compuesto',
    description: 'Simula cómo crece tu inversión con el interés compuesto. Aportaciones mensuales, ajuste por inflación y evolución año a año.',
    href: '/ahorro-inversion/interes-compuesto/',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    'name': 'CalculaTuDinero.net',
    'url': 'https://calculatudinero.net',
    'description': 'Calculadoras financieras gratuitas para autónomos y trabajadores en España.',
    'logo': 'https://calculatudinero.net/logo.png',
    'sameAs': [],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    'name': 'CalculaTuDinero.net',
    'url': 'https://calculatudinero.net',
    'potentialAction': {
      '@type': 'SearchAction',
      'target': 'https://calculatudinero.net/?q={search_term_string}',
      'query-input': 'required name=search_term_string',
    },
  },
];
---

<BaseLayout title={title} description={description} canonical="https://calculatudinero.net/" jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero__title">Calcula tus finanzas personales en España</h1>
      <p class="hero__subtitle">Calculadoras financieras gratuitas, actualizadas y precisas</p>
    </div>
  </section>

  <!-- Renta Campaign Banner -->
  <section class="renta-banner container">
    <a href="/declaracion-renta/" class="renta-banner__link">
      <span class="renta-banner__badge">Campaña 2025-2026</span>
      <span class="renta-banner__title">Declaración de la Renta</span>
      <span class="renta-banner__desc">Plazos, deducciones, calculadora y guía completa. Campaña abierta del 2 de abril al 30 de junio.</span>
      <span class="renta-banner__cta">Ver guía completa &rarr;</span>
    </a>
  </section>

  <!-- Calculator Cards -->
  <section class="calculators container">
    <div class="calculators__grid">
      {calculators.map((calc) => (
        <a href={calc.href} class="card card--accent calculator-card">
          <span class="calculator-card__icon">{calc.icon}</span>
          <h2 class="calculator-card__title">{calc.title}</h2>
          <p class="calculator-card__description">{calc.description}</p>
          <span class="calculator-card__cta">Calcular &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Trust Section -->
  <section class="trust container">
    <div class="trust__grid">
      <div class="trust__item">
        <span class="trust__icon">📅</span>
        <p class="trust__text">Datos actualizados a marzo 2026</p>
      </div>
      <div class="trust__item">
        <span class="trust__icon">✅</span>
        <p class="trust__text">Fórmulas verificadas con fuentes oficiales</p>
      </div>
      <div class="trust__item">
        <span class="trust__icon">🆓</span>
        <p class="trust__text">100% gratuito, sin registro</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background-color: var(--color-accent-light);
    padding: var(--space-16) 0 var(--space-12);
    text-align: center;
  }

  .hero__title {
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .hero__subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  /* Renta banner */
  .renta-banner {
    padding: var(--space-6) 0 0;
  }

  .renta-banner__link {
    display: block;
    padding: var(--space-6) var(--space-8);
    background: linear-gradient(135deg, #111110 0%, #2a1a10 100%);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: #fff;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .renta-banner__link:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    color: #fff;
  }

  .renta-banner__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background-color: var(--color-accent);
    padding: 2px 10px;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-2);
  }

  .renta-banner__title {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-bottom: var(--space-2);
  }

  .renta-banner__desc {
    display: block;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-3);
  }

  .renta-banner__cta {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-accent);
  }

  .calculators {
    padding: var(--space-12) 0;
  }

  .calculators__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  .calculator-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .calculator-card:hover {
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .calculator-card__icon {
    font-size: 1.75rem;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-light);
    border-radius: 14px;
    margin-bottom: var(--space-4);
  }

  .calculator-card__title {
    font-size: 1.25rem;
    margin-top: 0;
    margin-bottom: var(--space-2);
  }

  .calculator-card__description {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    flex-grow: 1;
  }

  .calculator-card__cta {
    font-weight: 600;
    color: var(--color-accent);
    margin-top: var(--space-3);
  }

  .trust {
    padding: var(--space-10) 0 var(--space-16);
  }

  .trust__grid {
    display: flex;
    justify-content: center;
    gap: var(--space-10);
    flex-wrap: wrap;
  }

  .trust__item {
    text-align: center;
    max-width: 200px;
  }

  .trust__icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: var(--space-2);
  }

  .trust__text {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .hero__title {
      font-size: 1.75rem;
    }

    .hero__subtitle {
      font-size: 1.05rem;
    }

    .calculators__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

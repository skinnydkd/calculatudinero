---
import CategoryLayout from '@layouts/CategoryLayout.astro';
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Calculadoras para Autonomos en Espana — CalculaTuDinero.es';
const description = 'Herramientas gratuitas para autonomos en Espana: calcula tu facturacion, cuota de Seguridad Social, IVA trimestral y mas.';
const canonical = 'https://calculatudinero.es/autonomos/';

const breadcrumbItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Autonomos' },
];

const calculators = [
  {
    icon: '\uD83D\uDCBC',
    title: 'Cuanto facturar como autonomo',
    description: 'Calcula cuanto necesitas facturar para conseguir el sueldo neto que quieres, teniendo en cuenta la cuota de autonomos, IRPF e IVA.',
    href: '/autonomos/cuanto-facturar/',
  },
];

const faqs = [
  {
    question: '\u00BFCuanto paga un autonomo de cuota en 2026?',
    answer: 'En 2026 la cuota de autonomos depende de los rendimientos netos y oscila entre 205,88 \u20AC/mes (para rendimientos hasta 670 \u20AC) y 607,35 \u20AC/mes (para rendimientos superiores a 6.000 \u20AC). La tarifa plana para nuevos autonomos es de 80 \u20AC/mes durante los primeros 12 meses.',
  },
  {
    question: '\u00BFQue impuestos paga un autonomo en Espana?',
    answer: 'Un autonomo paga la cuota de Seguridad Social (RETA), IRPF trimestral (modelo 130, entre el 7% y el 20% segun el regimen), IVA trimestral (21% general, modelo 303) y las declaraciones informativas y anuales correspondientes. Ademas, debe presentar la declaracion anual de la renta.',
  },
  {
    question: '\u00BFComo funciona el sistema de cotizacion por ingresos reales?',
    answer: 'Desde 2023, los autonomos cotizan segun sus rendimientos netos reales. Existen 15 tramos que van desde menos de 670 \u20AC/mes hasta mas de 6.000 \u20AC/mes. Cada tramo tiene una base minima y maxima de cotizacion, y la cuota se calcula aplicando el tipo total del 31,50% sobre la base elegida.',
  },
  {
    question: '\u00BFQue es la tarifa plana de autonomos?',
    answer: 'La tarifa plana permite a los nuevos autonomos pagar una cuota reducida de 80 \u20AC/mes durante los primeros 12 meses de actividad. Si los rendimientos netos durante ese primer ano son inferiores al SMI, se puede ampliar otros 12 meses mas. El requisito principal es no haber estado dado de alta como autonomo en los 2 anos anteriores.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': faqs.map((faq) => ({
      '@type': 'Question',
      'name': faq.question,
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': faq.answer,
      },
    })),
  },
];
---

<CategoryLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumbItems={breadcrumbItems}
  categoryTitle="Calculadoras para Autonomos"
  categoryDescription="Herramientas gratuitas para autonomos en Espana: calcula tu facturacion, cuota de Seguridad Social, IVA trimestral y mas."
>
  {calculators.map((calc) => (
    <a href={calc.href} class="card card--accent calculator-card">
      <span class="calculator-card__icon">{calc.icon}</span>
      <h2 class="calculator-card__title">{calc.title}</h2>
      <p class="calculator-card__description">{calc.description}</p>
      <span class="calculator-card__cta">Calcular &rarr;</span>
    </a>
  ))}
</CategoryLayout>

<!-- FAQ Section injected after CategoryLayout via BaseLayout slot -->
<section class="faq container">
  <h2>Preguntas frecuentes sobre autonomos</h2>
  {faqs.map((faq) => (
    <details class="faq__item">
      <summary class="faq__question">{faq.question}</summary>
      <p class="faq__answer">{faq.answer}</p>
    </details>
  ))}
</section>

<!-- JSON-LD for FAQPage -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd[0])} />

<style>
  .calculator-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .calculator-card:hover {
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .calculator-card__icon {
    font-size: 2rem;
    margin-bottom: var(--space-3);
  }

  .calculator-card__title {
    font-size: 1.25rem;
    margin-top: 0;
    margin-bottom: var(--space-2);
  }

  .calculator-card__description {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    flex-grow: 1;
  }

  .calculator-card__cta {
    font-weight: 600;
    color: var(--color-accent);
    margin-top: var(--space-3);
  }

  .faq {
    padding-bottom: var(--space-16);
  }

  .faq h2 {
    margin-bottom: var(--space-6);
  }

  .faq__item {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
  }

  .faq__question {
    font-weight: 600;
    cursor: pointer;
    font-size: 1.05rem;
    list-style: none;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::before {
    content: '+ ';
    color: var(--color-accent);
    font-weight: 700;
  }

  details[open] .faq__question::before {
    content: '- ';
  }

  .faq__answer {
    margin-top: var(--space-3);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
</style>

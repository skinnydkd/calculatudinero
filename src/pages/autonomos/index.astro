---
import CategoryLayout from '@layouts/CategoryLayout.astro';
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Calculadoras para Autónomos en España — CalculaTuDinero.net';
const description = 'Herramientas gratuitas para autónomos en España: calcula tu facturación, cuota de Seguridad Social, IVA trimestral y más.';
const canonical = 'https://calculatudinero.net/autonomos/';

const breadcrumbItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Autónomos' },
];

const calculators = [
  {
    icon: '💼',
    title: 'Cuánto facturar como autónomo',
    description: 'Calcula cuánto necesitas facturar para conseguir el sueldo neto que quieres, teniendo en cuenta la cuota de autónomos, IRPF e IVA.',
    href: '/autonomos/cuanto-facturar/',
  },
  {
    icon: '📋',
    title: 'Cuota de Autónomos 2026',
    description: 'Descubre qué cuota te corresponde según tus rendimientos netos con los 15 tramos del sistema de cotización por ingresos reales.',
    href: '/autonomos/cuota-autonomos/',
  },
];

const faqs = [
  {
    question: '¿Cuánto paga un autónomo de cuota en 2026?',
    answer: 'En 2026 la cuota de autónomos depende de los rendimientos netos y oscila entre 205,88 €/mes (para rendimientos hasta 670 €) y 607,35 €/mes (para rendimientos superiores a 6.000 €). La tarifa plana para nuevos autónomos es de 80 €/mes durante los primeros 12 meses.',
  },
  {
    question: '¿Qué impuestos paga un autónomo en España?',
    answer: 'Un autónomo paga la cuota de Seguridad Social (RETA), IRPF trimestral (modelo 130, entre el 7% y el 20% según el régimen), IVA trimestral (21% general, modelo 303) y las declaraciones informativas y anuales correspondientes. Además, debe presentar la declaración anual de la renta.',
  },
  {
    question: '¿Cómo funciona el sistema de cotización por ingresos reales?',
    answer: 'Desde 2023, los autónomos cotizan según sus rendimientos netos reales. Existen 15 tramos que van desde menos de 670 €/mes hasta más de 6.000 €/mes. Cada tramo tiene una base mínima y máxima de cotización, y la cuota se calcula aplicando el tipo total del 31,50% sobre la base elegida.',
  },
  {
    question: '¿Qué es la tarifa plana de autónomos?',
    answer: 'La tarifa plana permite a los nuevos autónomos pagar una cuota reducida de 80 €/mes durante los primeros 12 meses de actividad. Si los rendimientos netos durante ese primer año son inferiores al SMI, se puede ampliar otros 12 meses más. El requisito principal es no haber estado dado de alta como autónomo en los 2 años anteriores.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': faqs.map((faq) => ({
      '@type': 'Question',
      'name': faq.question,
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': faq.answer,
      },
    })),
  },
];
---

<CategoryLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumbItems={breadcrumbItems}
  categoryTitle="Calculadoras para Autónomos"
  categoryDescription="Herramientas gratuitas para autónomos en España: calcula tu facturación, cuota de Seguridad Social, IVA trimestral y más."
>
  {calculators.map((calc) => (
    <a href={calc.href} class="card card--accent calculator-card">
      <span class="calculator-card__icon">{calc.icon}</span>
      <h2 class="calculator-card__title">{calc.title}</h2>
      <p class="calculator-card__description">{calc.description}</p>
      <span class="calculator-card__cta">Calcular &rarr;</span>
    </a>
  ))}
</CategoryLayout>

<!-- FAQ Section injected after CategoryLayout via BaseLayout slot -->
<section class="faq container">
  <h2>Preguntas frecuentes sobre autónomos</h2>
  {faqs.map((faq) => (
    <details class="faq__item">
      <summary class="faq__question">{faq.question}</summary>
      <p class="faq__answer">{faq.answer}</p>
    </details>
  ))}
</section>

<!-- JSON-LD for FAQPage -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd[0])} />

<style>
  .calculator-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .calculator-card:hover {
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .calculator-card__icon {
    font-size: 1.75rem;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-light);
    border-radius: 14px;
    margin-bottom: var(--space-4);
  }

  .calculator-card__title {
    font-size: 1.25rem;
    margin-top: 0;
    margin-bottom: var(--space-2);
  }

  .calculator-card__description {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    flex-grow: 1;
  }

  .calculator-card__cta {
    font-weight: 600;
    color: var(--color-accent);
    margin-top: var(--space-3);
  }

  .faq {
    padding-bottom: var(--space-16);
  }

  .faq h2 {
    margin-bottom: var(--space-6);
  }

  .faq__item {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
  }

  .faq__question {
    font-weight: 600;
    cursor: pointer;
    font-size: 1.05rem;
    list-style: none;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::before {
    content: '+ ';
    color: var(--color-accent);
    font-weight: 700;
  }

  details[open] .faq__question::before {
    content: '- ';
  }

  .faq__answer {
    margin-top: var(--space-3);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
</style>

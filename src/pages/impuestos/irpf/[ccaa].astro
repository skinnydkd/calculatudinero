    particularidad: 'Ceuta aplica la escala estatal como tramo autonómico, pero los residentes disfrutan de una bonificación del 60% de la cuota íntegra, lo que reduce significativamente el IRPF efectivo.',
    deducciones: ['Bonificación del 60% de la cuota íntegra por residencia en Ceuta', 'Las mismas deducciones estatales generales'],
    comparativa: 'Gracias a la bonificación del 60%, los residentes en Ceuta pagan efectivamente menos IRPF que en cualquier otra comunidad.',
    esForal: false,
  },
  'melilla': {

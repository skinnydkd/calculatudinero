import { CCAA_OPTIONS } from '@lib/types';
import type { ComunidadAutonoma, TramoIRPF } from '@lib/types';
import { calcularCuotaPorTramos } from '@lib/calculations/shared';
import { round2, formatCurrency, formatPercent } from '@lib/formatters';

// ---------------------------------------------------------------------------
// Static paths — one page per CCAA
// ---------------------------------------------------------------------------

export function getStaticPaths() {
  return CCAA_OPTIONS.map((opt) => ({
    params: { ccaa: opt.value },
    props: { ccaaValue: opt.value, ccaaLabel: opt.label },
  }));
}

const { ccaaValue, ccaaLabel } = Astro.props;

// ---------------------------------------------------------------------------
// Unique content data per CCAA
// ---------------------------------------------------------------------------


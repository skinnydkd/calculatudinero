// ---------------------------------------------------------------------------
// IRPF computation helper for salary examples
// ---------------------------------------------------------------------------

const ccaaData = (irpfData.tramosAutonomicos as Record<string, any>)[ccaaValue];
const isForal = ccaaData?.regimenForal === true;
const hasDeduccionResidentes = typeof ccaaData?.deduccionResidentes === 'number';
const tramosAut: TramoIRPF[] = ccaaData?.tramos ?? irpfData.tramosEstatales;

function computeIRPF(salary: number): number {
  const ss = round2(salary * 0.0647);
  const rendNetos = salary - ss;

  // Reducción por rendimientos del trabajo
  let reduccion = 0;
  if (rendNetos <= 14852) {
    reduccion = 7302;
  } else if (rendNetos <= 17673.52) {
    reduccion = Math.max(0, 7302 - 1.75 * (rendNetos - 14852));
  }

  const baseLiq = Math.max(0, rendNetos - reduccion);
  const minPersonal = irpfData.minimoPersonal;

  if (isForal) {
    const ci = calcularCuotaPorTramos(baseLiq, tramosAut);
    const cm = calcularCuotaPorTramos(minPersonal, tramosAut);
    return round2(Math.max(0, ci - cm));
  }

  // Régimen común: estatal + autonómico
  const ce = calcularCuotaPorTramos(baseLiq, irpfData.tramosEstatales);
  const cme = calcularCuotaPorTramos(minPersonal, irpfData.tramosEstatales);
  const ca = calcularCuotaPorTramos(baseLiq, tramosAut);
  const cma = calcularCuotaPorTramos(minPersonal, tramosAut);

  let cuota = round2(Math.max(0, ce - cme) + Math.max(0, ca - cma));

  // Deducción del 60% para residentes en Ceuta/Melilla
  if (hasDeduccionResidentes) {
    const pct = ccaaData.deduccionResidentes / 100;
    cuota = round2(cuota * (1 - pct));
  }

  return cuota;
}

// Pre-compute examples for 25K, 40K, 60K
const ejemplos = [25000, 40000, 60000].map((salary) => {
  const irpf = computeIRPF(salary);
  const tipoEfectivo = salary > 0 ? round2((irpf / salary) * 100) : 0;
  return { salary, irpf, tipoEfectivo };
});

// ---------------------------------------------------------------------------
// SEO metadata
// ---------------------------------------------------------------------------

const info = ccaaInfo[ccaaValue] ?? {
  tipoMaximo: 'N/D',
  particularidad: '',
  deducciones: [],
  comparativa: '',
  esForal: false,
};

const title = `IRPF en ${ccaaLabel} 2026: Tramos, Tipos y Calculadora — CalculaTuDinero.net`;
const description = `Calcula tu IRPF en ${ccaaLabel} con los tramos autonómicos actualizados a 2026. Tipos, deducciones y calculadora gratuita.`;
const canonical = `https://calculatudinero.net/impuestos/irpf/${ccaaValue}/`;

const breadcrumbItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Impuestos', href: '/impuestos/' },
  { label: 'IRPF', href: '/impuestos/calculadora-irpf/' },
  { label: ccaaLabel },
];

// ---------------------------------------------------------------------------
// FAQs — unique per CCAA
// ---------------------------------------------------------------------------

const regimeLabel = info.esForal ? 'régimen foral propio' : 'régimen común';
const regimeExplain = info.esForal
  ? `${ccaaLabel} tiene régimen foral, lo que significa que aplica una escala de IRPF propia y única, sin dividirse en parte estatal y autonómica. Los tipos y tramos se fijan por la hacienda foral, no por la AEAT.`
  : `${ccaaLabel} aplica el régimen común del IRPF, que se divide en dos partes: la estatal (igual en toda España) y la autonómica (fijada por la comunidad). La suma de ambas partes determina el tipo total que pagas.`;

const faqs = [
  {
    question: `¿Qué tipo de régimen fiscal tiene ${ccaaLabel}?`,
    answer: regimeExplain,
  },
  {
    question: `¿Cuál es el tipo máximo de IRPF en ${ccaaLabel} en 2026?`,
    answer: `El tipo máximo ${info.esForal ? '' : 'autonómico '}en ${ccaaLabel} es del ${info.tipoMaximo}. ${info.comparativa}`,
  },
  {
    question: `¿Cuánto IRPF pago con un salario de 40.000 euros en ${ccaaLabel}?`,
    answer: `Con un salario bruto de 40.000 euros en ${ccaaLabel}, sin hijos y soltero, la cuota de IRPF es de aproximadamente ${formatCurrency(ejemplos[1].irpf)}, lo que supone un tipo efectivo del ${formatPercent(ejemplos[1].tipoEfectivo)}. Esta cifra incluye la cotización a la Seguridad Social del trabajador.`,
  },
];

// ---------------------------------------------------------------------------
// JSON-LD schemas
// ---------------------------------------------------------------------------

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    'name': `Calculadora IRPF ${ccaaLabel} 2026`,
    'url': canonical,
    'applicationCategory': 'FinanceApplication',
    'operatingSystem': 'Web',
    'offers': {
      '@type': 'Offer',
      'price': '0',
      'priceCurrency': 'EUR',
    },
    'description': description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': faqs.map((faq) => ({
      '@type': 'Question',
      'name': faq.question,
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': faq.answer,
      },
    })),
  },
];

// ---------------------------------------------------------------------------
// Helper to format tramo ranges for the table
// ---------------------------------------------------------------------------

function formatTramo(tramo: TramoIRPF): string {
  const desde = tramo.desde.toLocaleString('es-ES');
  if (tramo.hasta === null) return `Más de ${desde} €`;
  const hasta = tramo.hasta.toLocaleString('es-ES');
  return `${desde} € – ${hasta} €`;
}
---

<CalculatorLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
  breadcrumbItems={breadcrumbItems}
  lastUpdated="marzo 2026"
  calculatorName={`IRPF en ${ccaaLabel} 2026`}
>
  <CalculadoraIRPF client:load irpfData={irpfData} />

  <Fragment slot="content">
    <p class="intro">
      {info.esForal ? (
        `${ccaaLabel} tiene ${regimeLabel} con una escala de IRPF propia. ${info.particularidad} A continuación encontrarás los tramos, ejemplos de cuotas calculadas y las principales deducciones autonómicas.`
      ) : (
        `El IRPF en ${ccaaLabel} combina la escala estatal (común a toda España) con una escala autonómica propia. ${info.particularidad} A continuación encontrarás los tramos, ejemplos de cuotas calculadas y las principales deducciones autonómicas.`
      )}
    </p>

    <h2>{info.esForal ? `Tramos del IRPF en ${ccaaLabel} 2026 (escala foral)` : `Tramos autonómicos del IRPF en ${ccaaLabel} 2026`}</h2>
    {info.esForal ? (
      <p>
        Al tener régimen foral, {ccaaLabel} aplica una escala única que sustituye la doble escala estatal + autonómica del régimen común. Estos son los tramos vigentes en 2026:
      </p>
    ) : (
      <p>
        La escala autonómica se aplica sobre la misma base liquidable que la estatal. Ambas cuotas se suman para obtener el IRPF total. Los tramos autonómicos de {ccaaLabel} en 2026 son:
      </p>
    )}

    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Base liquidable</th>
            <th>Tipo {info.esForal ? '' : 'autonómico'}</th>
          </tr>
        </thead>
        <tbody>
          {tramosAut.map((tramo) => (
            <tr>
              <td>{formatTramo(tramo)}</td>
              <td class="mono">{formatPercent(tramo.tipo, 2)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    {!info.esForal && (
      <p class="note">
        Estos tramos corresponden a la parte autonómica del IRPF. Se suman a los tramos estatales (del 9,50% al 24,50%) para calcular la cuota total.
      </p>
    )}

    {hasDeduccionResidentes && (
      <p class="note">
        Los residentes en {ccaaLabel} disfrutan de una bonificación del {ccaaData.deduccionResidentes}% sobre la cuota íntegra, lo que reduce significativamente el IRPF efectivo.
      </p>
    )}

    <h2>Tipo efectivo en {ccaaLabel}</h2>
    <p>
      ¿Cuánto IRPF se paga realmente en {ccaaLabel}? El tipo efectivo (porcentaje real sobre el salario bruto) es siempre menor que el tipo marginal máximo, porque los primeros tramos tributan a tipos más bajos. Estos son ejemplos para un trabajador por cuenta ajena, soltero y sin hijos:
    </p>

    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Salario bruto anual</th>
            <th>Cuota IRPF</th>
            <th>Tipo efectivo</th>
          </tr>
        </thead>
        <tbody>
          {ejemplos.map((ej) => (
            <tr>
              <td class="mono">{formatCurrency(ej.salary)}</td>
              <td class="mono">{formatCurrency(ej.irpf)}</td>
              <td class="mono">{formatPercent(ej.tipoEfectivo)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="note">
      Cálculos para un asalariado con contrato indefinido, sin hijos, menor de 65 años, con cotización a la Seguridad Social estimada del 6,47%. La cuota incluye la parte estatal y la autonómica{hasDeduccionResidentes ? `, con la bonificación del ${ccaaData.deduccionResidentes}% aplicada` : ''}.
    </p>

    <h2>Comparativa con otras comunidades</h2>
    <p>
      {info.comparativa}
    </p>
    <p>
      Si quieres comparar el IRPF de {ccaaLabel} con el resto de comunidades para tu salario concreto, usa nuestro <a href="/impuestos/comparador-irpf-comunidades/">comparador de IRPF por comunidades autónomas</a>.
    </p>

    <h2>Deducciones autonómicas en {ccaaLabel}</h2>
    <p>
      Además de las deducciones estatales (mínimo personal, descendientes, ascendientes, discapacidad), {ccaaLabel} ofrece deducciones propias que pueden reducir tu cuota autonómica:
    </p>
    <ul>
      {info.deducciones.map((ded) => (
        <li>{ded}</li>
      ))}
    </ul>
    <p class="note">
      Las deducciones autonómicas tienen requisitos y límites específicos. Consulta la normativa fiscal de {ccaaLabel} para verificar las condiciones de cada deducción.
    </p>

    <h2>Preguntas frecuentes sobre IRPF en {ccaaLabel}</h2>
    {faqs.map((faq) => (
      <details class="faq__item">
        <summary class="faq__question">{faq.question}</summary>
        <p class="faq__answer">{faq.answer}</p>
      </details>
    ))}
  </Fragment>

  <Fragment slot="related">
    <RelatedCalculators items={[
      { icon: '📊', title: 'Comparador IRPF por comunidades', description: 'Compara el IRPF que pagarías en las 19 comunidades autónomas.', href: '/impuestos/comparador-irpf-comunidades/' },
      { icon: '💰', title: 'Salario neto', description: 'Calcula tu salario neto a partir del bruto anual.', href: '/laboral/salario-neto/' },
      { icon: '💼', title: 'Cuánto facturar como autónomo', description: 'Calcula tu facturación necesaria como autónomo.', href: '/autonomos/cuanto-facturar/' },
    ]} />
  </Fragment>
</CalculatorLayout>

<style>
  .intro {
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: var(--space-8);
  }

  .table-wrapper {
    overflow-x: auto;
    margin: var(--space-6) 0;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .data-table th {
    font-weight: 600;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background-color: var(--color-bg-alt);
  }

  .data-table tbody tr:hover {
    background-color: var(--color-bg-alt);
  }

  .mono {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }

  .note {
    font-size: 0.88rem;
    color: var(--color-text-secondary);
    font-style: italic;
    line-height: 1.6;
  }

  ul {
    padding-left: var(--space-6);
    margin: var(--space-4) 0;

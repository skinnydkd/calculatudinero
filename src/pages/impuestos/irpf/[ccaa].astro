    deducciones: ['Deducción por inversión en vivienda habitual para jóvenes', 'Deducción por gastos de guardería de hijos menores de 3 años', 'Deducción por nacimiento o adopción'],
    comparativa: 'Murcia es una de las comunidades con menor presión fiscal en los tramos altos, junto a Madrid y Castilla y León.',
    esForal: false,
  },

---
import CalculatorLayout from '@layouts/CalculatorLayout.astro';
import PlusvaliaMunicipal from '@components/calculators/PlusvaliaMunicipal';
import plusvaliaRawData from '@data/plusvalia-municipal.json';

const plusvaliaData = {
  tipoImpositivoMaximo: plusvaliaRawData.tipoImpositivoMaximo,
  tipoImpositivoComun: plusvaliaRawData.tipoImpositivoComun,
  coeficientesObjetivo: plusvaliaRawData.coeficientesObjetivo,
  porcentajeSueloDefault: plusvaliaRawData.porcentajeSueloDefault,
};

const title = 'Calculadora de Plusvalía Municipal 2026 — CalculaTuDinero.net';
const description = 'Calcula la plusvalía municipal por la venta de tu vivienda. Compara método real y objetivo para elegir el más favorable (STC 182/2021).';
const canonical = 'https://calculatudinero.net/impuestos/plusvalia-municipal/';

const breadcrumbItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Impuestos', href: '/impuestos/' },
  { label: 'Plusvalía municipal' },
];

const faqs = [
  {
    question: '¿Qué es la plusvalía municipal?',
    answer: 'La plusvalía municipal, oficialmente llamada Impuesto sobre el Incremento de Valor de los Terrenos de Naturaleza Urbana (IIVTNU), es un impuesto que grava el incremento de valor que experimentan los terrenos urbanos cuando se transmiten (por venta, herencia, donación, etc.). Lo gestiona y recauda cada ayuntamiento, que fija su propio tipo impositivo hasta un máximo del 30%.',
  },
  {
    question: '¿Qué cambió con la sentencia STC 182/2021?',
    answer: 'El Tribunal Constitucional declaró inconstitucional el sistema de cálculo anterior porque presumía que siempre había ganancia, incluso cuando el propietario vendía a pérdidas. Desde noviembre de 2021 (Real Decreto-ley 26/2021), si no existe incremento de valor real (precio de venta inferior al de compra), no se paga plusvalía. Además, se introdujeron dos métodos de cálculo y el contribuyente puede elegir el más favorable.',
  },
  {
    question: '¿Cómo se calcula la plusvalía por el método real?',
    answer: 'El método real toma la ganancia real de la operación (precio de venta menos precio de compra) y la multiplica por la proporción del valor catastral que corresponde al suelo respecto al valor de transmisión. Sobre esa base imponible se aplica el tipo impositivo del municipio. Fórmula: (valor venta - valor compra) x (valor catastral suelo / valor transmisión) x tipo impositivo.',
  },
  {
    question: '¿Cómo se calcula la plusvalía por el método objetivo?',
    answer: 'El método objetivo multiplica el valor catastral del suelo por un coeficiente que fija el Ministerio de Hacienda en función de los años de tenencia del inmueble. Sobre esa base imponible se aplica el tipo impositivo municipal. Los coeficientes se actualizan anualmente por orden ministerial y tienden a ser más altos cuantos más años de propiedad, salvo para periodos superiores a 20 años.',
  },
  {
    question: '¿Quién tiene que pagar la plusvalía municipal?',
    answer: 'En las compraventas paga el vendedor (transmitente). En las herencias y donaciones paga quien recibe el bien (adquirente). El plazo para presentar la liquidación es de 30 días hábiles desde la transmisión, o de 6 meses (prorrogable a 12) en caso de herencia. No pagarla o presentarla fuera de plazo puede conllevar recargos e intereses de demora.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    'name': 'Calculadora de Plusvalía Municipal 2026',
    'url': canonical,
    'applicationCategory': 'FinanceApplication',
    'operatingSystem': 'Web',
    'offers': {
      '@type': 'Offer',
      'price': '0',
      'priceCurrency': 'EUR',
    },
    'description': description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': faqs.map((faq) => ({
      '@type': 'Question',
      'name': faq.question,
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': faq.answer,
      },
    })),
  },
];
---

<CalculatorLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
  breadcrumbItems={breadcrumbItems}
  lastUpdated="marzo 2026"
  calculatorName="Calculadora de Plusvalía Municipal 2026"
>
  <PlusvaliaMunicipal client:load plusvaliaData={plusvaliaData} />

  <Fragment slot="content">
    <h2>Qué es la plusvalía municipal y cómo se calcula</h2>
    <p>
      La plusvalía municipal es el impuesto que pagan los propietarios de terrenos urbanos cuando
      los transmiten por venta, herencia o donación. Su nombre oficial es Impuesto sobre el Incremento
      de Valor de los Terrenos de Naturaleza Urbana (IIVTNU) y lo gestiona cada ayuntamiento, que
      decide el tipo impositivo aplicable hasta un máximo legal del 30%.
    </p>
    <p>
      Tras la sentencia del Tribunal Constitucional 182/2021, el sistema de cálculo cambió
      radicalmente. Si vendes tu vivienda por un precio igual o inferior al que pagaste,
      <strong>no tienes que pagar plusvalía municipal</strong>. Cuando sí existe ganancia, puedes
      elegir entre dos métodos de cálculo y tributar por el que resulte más favorable.
    </p>

    <h2>Los dos métodos de cálculo</h2>
    <h3>Método real</h3>
    <p>
      Parte de la ganancia real de la operación. Se calcula la diferencia entre el valor de
      transmisión (precio de venta) y el valor de adquisición (precio de compra), y se multiplica
      por la proporción del valor catastral que corresponde al suelo dividida entre el valor de
      transmisión. Sobre esa base imponible se aplica el tipo impositivo municipal.
    </p>
    <p>
      <strong>Fórmula:</strong> Base imponible = (Valor venta - Valor compra) x (Valor catastral suelo / Valor transmisión).
      Cuota = Base imponible x tipo impositivo.
    </p>

    <h3>Método objetivo</h3>
    <p>
      Utiliza coeficientes multiplicadores fijados anualmente por el Ministerio de Hacienda
      (Orden HFP) en función de los años transcurridos desde la adquisición hasta la transmisión.
      Se multiplica el valor catastral del suelo por el coeficiente correspondiente, y sobre esa
      base imponible se aplica el tipo impositivo.
    </p>
    <p>
      <strong>Fórmula:</strong> Base imponible = Valor catastral suelo x coeficiente.
      Cuota = Base imponible x tipo impositivo.
    </p>

    <h2>Ejemplo práctico</h2>
    <p>
      <strong>Compra por 150.000 € y venta por 200.000 €</strong>, con un valor catastral de
      80.000 € (50% suelo = 40.000 €), 10 años de propiedad y tipo impositivo del 30%:
    </p>
    <p>
      <strong>Método real:</strong> Incremento real = 200.000 - 150.000 = 50.000 €.
      Base imponible = 50.000 x (40.000 / 200.000) = 10.000 €.
      Cuota = 10.000 x 30% = <strong>3.000 €</strong>.
    </p>
    <p>
      <strong>Método objetivo:</strong> Coeficiente para 10 años = 0,35.
      Base imponible = 40.000 x 0,35 = 14.000 €.
      Cuota = 14.000 x 30% = <strong>4.200 €</strong>.
    </p>
    <p>
      En este caso, el <strong>método real es más favorable</strong> y supone un ahorro de 1.200 €
      respecto al método objetivo.
    </p>

    <h2>Dónde encontrar los datos necesarios</h2>
    <p>
      El <strong>valor catastral</strong> y el <strong>porcentaje de suelo</strong> aparecen en el
      recibo del IBI (Impuesto sobre Bienes Inmuebles) que paga anualmente todo propietario. También
      puedes consultarlo en la Sede Electrónica del Catastro. El <strong>tipo impositivo</strong> lo
      fija la ordenanza fiscal de cada municipio; si no lo conoces, puedes usar el máximo legal del
      30% como referencia conservadora.
    </p>

    <h2>Calculadoras relacionadas</h2>
    <p>
      Si estás vendiendo una vivienda, también te interesará calcular el
      <a href="/impuestos/calculadora-irpf/">IRPF sobre la ganancia patrimonial</a> y los
      <a href="/vivienda/gastos-compra-vivienda/">gastos de compra de vivienda</a> si vas a
      reinvertir. También puedes estimar tu
      <a href="/vivienda/calculadora-hipoteca/">cuota hipotecaria</a> si necesitas financiación
      para la nueva compra.
    </p>

    <h2>Preguntas frecuentes</h2>
    {faqs.map((faq) => (
      <details class="faq__item">
        <summary class="faq__question">{faq.question}</summary>
        <p class="faq__answer">{faq.answer}</p>
      </details>
    ))}
  </Fragment>
</CalculatorLayout>

<style>
  .faq__item {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
  }

  .faq__question {
    font-weight: 600;
    cursor: pointer;
    font-size: 1.05rem;
    list-style: none;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::before {
    content: '+ ';
    color: var(--color-accent);
    font-weight: 700;
  }

  details[open] .faq__question::before {
    content: '- ';
  }

  .faq__answer {
    margin-top: var(--space-3);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* Plusvalía-specific component styles */
  .plusvalia-comparison {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin: var(--space-6) 0;
  }

  @media (max-width: 640px) {
    .plusvalia-comparison {
      grid-template-columns: 1fr;
    }
  }

  .plusvalia-method {
    position: relative;
    padding: var(--space-4);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
  }

  .plusvalia-method--selected {
    border-color: var(--color-accent);
    background: var(--color-accent-light);
  }

  .plusvalia-method__badge {
    position: absolute;
    top: calc(-1 * var(--space-3));
    right: var(--space-3);
    padding: var(--space-1) var(--space-3);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: white;
    background: var(--color-accent);
    border-radius: var(--radius-sm);
  }

  .plusvalia-method__title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    margin-bottom: var(--space-2);
  }

  .plusvalia-method__amount {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .plusvalia-method--selected .plusvalia-method__amount {
    color: var(--color-accent);
  }

  .plusvalia-method__table {
    width: 100%;
    font-size: 0.85rem;
    border-collapse: collapse;
  }

  .plusvalia-method__table td {
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .plusvalia-method__table td:last-child {
    text-align: right;
    font-family: var(--font-mono);
  }

  .plusvalia-notice {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    margin: var(--space-4) 0;
  }

  .plusvalia-notice--success {
    background: color-mix(in srgb, var(--color-success) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-success) 30%, transparent);
  }

  .plusvalia-notice--info {
    background: color-mix(in srgb, var(--color-info) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-info) 30%, transparent);
  }

  .plusvalia-notice__icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    line-height: 1.4;
  }

  .plusvalia-notice--success .plusvalia-notice__icon {
    color: var(--color-success);
  }

  .plusvalia-notice--info .plusvalia-notice__icon {
    color: var(--color-info);
  }

  .plusvalia-notice__title {
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: var(--space-2);
  }

  .plusvalia-notice--success .plusvalia-notice__title {
    color: var(--color-success);
  }

  .plusvalia-notice__text {
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
  }
</style>

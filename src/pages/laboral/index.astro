<style>
  .calculator-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .calculator-card:hover {
    transform: translateY(-2px);
    color: var(--color-text);
